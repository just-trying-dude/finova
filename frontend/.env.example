# Backend API (Render) — required for production builds on Vercel
# No trailing slash. No /api prefix (routes are at root, e.g. /login, /portfolio/dashboard).
VITE_API_URL=https://your-finova-api.onrender.com

# Local development (optional; dev server defaults to http://127.0.0.1:8000)
# VITE_API_URL=http://127.0.0.1:8000
