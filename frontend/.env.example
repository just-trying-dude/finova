# Backend API (Render) — REQUIRED for Vercel production builds
# Set in Vercel Dashboard → Settings → Environment Variables
# Enable for: Production, Preview, AND Development
# No trailing slash. No /api prefix.
VITE_API_URL=https://your-finova-api.onrender.com

# Local only (optional — npm run dev defaults to http://127.0.0.1:8000)
# VITE_API_URL=http://127.0.0.1:8000
