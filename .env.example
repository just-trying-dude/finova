# --- Runtime ---
# development | production
ENV=development

# Render sets PORT automatically; local default is 8000
PORT=8000

# --- MongoDB (required in production) ---
MONGO_URI=mongodb://localhost:27017
# Alternative name supported: MONGODB_URI
MONGO_DB_NAME=trading_app

# --- JWT (required in production; use a long random string) ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
# Standard session length (minutes), default 24h
JWT_EXPIRES_MINUTES=1440
# Remember-me duration (days)
JWT_REMEMBER_DAYS=30

# --- CORS / frontend ---
# Comma-separated allowed origins (in addition to localhost dev URLs)
CORS_ORIGINS=
# Shorthand for a single deployed frontend (e.g. Vercel)
VERCEL_FRONTEND_URL=https://your-app.vercel.app
# Example: CORS_ORIGINS=https://your-app.vercel.app,https://your-app-git-main.vercel.app

# --- Optional ---
# Seed test user (username: test, password: 1234) — default on in development only
CREATE_TEST_USER=true
